# ============================================
# Supabase 配置
# ============================================
# 1. 访问 https://supabase.com 注册账号并创建项目
# 2. 进入项目 Dashboard → Project Settings → API
# 3. 复制 Project URL 和 anon public 填入下方
#
# 注意：anon key 是公开的，可以放在前端代码中
#       service_role key 只能放在服务端，不要泄露！
# ============================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# OpenAI API Key（可选）
# 用于在线测试 prompt 效果
# 在 https://platform.openai.com/api-keys 获取
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
